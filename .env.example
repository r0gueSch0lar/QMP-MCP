# qmp-mcp configuration — every knob is a QMP_MCP_* environment variable.
#
# Copy to `.env` (or export in your shell / pass via `docker run -e ...`) and edit.
# Values shown after `=` are the DEFAULTS; commented lines mean "unset" (the
# default applies). Every value is validated at startup and FAILS CLOSED: an
# invalid value aborts boot with a message naming the variable and what it expects,
# rather than silently falling back. See README.md and docs/adr/ for the rationale.

# ── Transport & authentication (ADR-0005) ───────────────────────────────────────
# Which transport(s) to expose: stdio | http | both.
QMP_MCP_TRANSPORT=stdio
# Address the HTTP transport binds to. The Docker image overrides this to 0.0.0.0
# so the published port is reachable; on bare metal keep it on loopback.
QMP_MCP_HTTP_HOST=127.0.0.1
# TCP port the HTTP transport listens on (1-65535).
QMP_MCP_HTTP_PORT=8080
# Path the MCP endpoint is served from.
QMP_MCP_HTTP_ENDPOINT=/mcp
# Comma-separated browser origins allowed by the DNS-rebinding/CORS guard. Requests
# with no Origin header (curl, MCP SDK clients) are always allowed; a browser
# Origin not in this list is rejected with 403. Defaults to the loopback origins
# for the configured port.
# QMP_MCP_HTTP_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Which provider guards the HTTP transport: apikey | jwt.
QMP_MCP_AUTH=apikey
# Comma-separated valid API keys (sent in the X-API-Key header) for QMP_MCP_AUTH=apikey.
# HTTP REFUSES to start without this (or a JWT secret) unless QMP_MCP_ALLOW_INSECURE=true.
# QMP_MCP_API_KEYS=change-me-key-1,change-me-key-2
# HS256 signing secret for QMP_MCP_AUTH=jwt. Required for HTTP+jwt without insecure.
# QMP_MCP_JWT_SECRET=
# Run the HTTP transport WITHOUT authentication. Local dev only — never expose the
# port on an untrusted network when this is true.
QMP_MCP_ALLOW_INSECURE=false

# ── Logging ─────────────────────────────────────────────────────────────────────
# Minimum severity the server's own (stderr-only) logger emits: debug | info | warning | error.
QMP_MCP_LOG_LEVEL=info

# ── Image & ISO Stores (ADR-0006) ───────────────────────────────────────────────
# Read-write Image Store directory: the single allowlisted dir guest disk images
# live in and are created into (referenced by name, never by host path). Defaults
# to a host-agnostic XDG/HOME path; the Docker image overrides it via env.
# QMP_MCP_IMAGE_DIR=/var/lib/qmp-mcp/images
# Read-only ISO Store directory: a SEPARATE allowlisted dir for install/boot ISO
# media (referenced by name, never written to).
# QMP_MCP_ISO_DIR=/var/lib/qmp-mcp/isos
# Hard cap, in GiB, on the virtual size create_image may allocate.
QMP_MCP_MAX_DISK_GB=64

# ── QEMU binary / guest architecture (issue #18, ADR-0013) ──────────────────────
# LEAVE THIS UNSET in most setups: the qemu-system-* binary is DERIVED per-instance
# from the spec's machine — q35/pc -> qemu-system-x86_64, virt/sbsa-ref/raspi* ->
# qemu-system-aarch64 — so switching guest architectures is just a different machine,
# no restart. Set it only to OVERRIDE that choice for every Instance (e.g. a custom
# build, or qemu-system-riscv64 for a machine the map doesn't recognize). It is exec'd
# as argv[0] with NO shell; the value must be a bare command name (resolved via PATH)
# or an absolute path over [A-Za-z0-9._/+-] — whitespace, shell metacharacters,
# control characters, and relative paths are rejected at startup (fail-closed).
# QMP_MCP_QEMU_BINARY=qemu-system-aarch64

# ── Resource caps (issue #9) ────────────────────────────────────────────────────
# Hard cap, in MiB, on a Hardware Spec's memoryMb. An over-cap spec is rejected
# before qemu is spawned.
QMP_MCP_MAX_MEMORY_MB=4096
# Hard cap on a Hardware Spec's vcpus. An over-cap spec is rejected before launch.
QMP_MCP_MAX_VCPUS=2

# ── Guest networking (ADR-0009) ─────────────────────────────────────────────────
# Inclusive host-port range "LOW-HIGH" a user-mode port-forward's hostPort must
# fall within. Defaults to the IANA non-privileged range so a forward never needs
# root/CAP_NET_BIND_SERVICE.
QMP_MCP_HOSTFWD_PORT_RANGE=1024-65535
# Permit host-level (tap/bridge) guest networking. Default false: only user-mode
# (SLiRP) NAT is allowed, since host networking needs privileges incompatible with
# the non-root posture. The operator must provision the host bridge/tap themselves.
QMP_MCP_ALLOW_HOST_NET=false

# Auto-start the Guest on create_instance. Default false: the Guest loads PAUSED
# (CPUs frozen at the -S startup pause) for deterministic inspection and only runs
# on an explicit resume_instance. Set true to issue QMP `cont` right after launch so
# create_instance returns a Guest that is already executing.
QMP_MCP_AUTO_START=false

# ── Command Policy for qmp_execute (ADR-0003) ───────────────────────────────────
# Comma-separated QMP command names to ADD to the default-safe allowlist.
# QMP_MCP_ALLOW=
# Comma-separated QMP command names to REMOVE from the allowlist. (The immutable
# hard denylist — human-monitor-command, migrate, dump-guest-memory, etc. — can
# never be re-enabled by any of these.)
# QMP_MCP_DENY=
# Path to a YAML policy file ({ allow?: string[], deny?: string[] }) layered onto
# the allowlist. A missing/malformed file fails closed at startup.
# QMP_MCP_POLICY_FILE=/etc/qmp-mcp/policy.yaml

# ── Events (issue #12) ──────────────────────────────────────────────────────────
# Capacity of the bounded Event Buffer of recent QMP async events. Once full, the
# oldest event is evicted.
QMP_MCP_EVENT_BUFFER_SIZE=256

# ── noVNC Viewer (ADR-0010) ─────────────────────────────────────────────────────
# The optional browser Viewer bridges a Guest's vnc Display (Hardware Spec
# display: vnc) to a browser. It runs on its OWN HTTP server, independent of the MCP
# transport (so it works even with QMP_MCP_TRANSPORT=stdio), and is FAIL-CLOSED: the
# page and the websocket are refused unless the request authenticates with this
# password, and requesting display: vnc while it is unset REJECTS create_instance.
# There is no default — leaving it unset disables the Viewer entirely.
# QMP_MCP_VIEWER_PASSWORD=change-me-viewer-password
# OPTIONAL username enforced alongside the password on the Viewer's HTTP Basic auth.
# When set, the browser must supply this username too (constant-time compared); when
# unset (the default) the username is ignored and only the password is checked.
# QMP_MCP_VIEWER_USER=viewer
# Address the Viewer's HTTP server binds to. The Docker image overrides this to
# 0.0.0.0 so the published port is reachable; on bare metal keep it on loopback.
# The Viewer serves plain HTTP, so the Basic password and the interactive VNC
# session travel in CLEARTEXT: a non-loopback bind (anything other than
# 127.0.0.1/localhost/::1) logs a startup WARNING — front it with a TLS-terminating
# reverse proxy on any untrusted network.
QMP_MCP_VIEWER_HOST=127.0.0.1
# TCP port the Viewer listens on (1-65535). Open http://<host>:<port>/ in a browser.
QMP_MCP_VIEWER_PORT=6080

# ── Raw-args escape hatch (ADR-0002) ────────────────────────────────────────────
# Allow a Hardware Spec's `extraArgs` (raw QEMU arguments) to be appended to the
# generated argv. Default false: raw args are host-compromise-equivalent, so a spec
# carrying extraArgs is REFUSED unless this is enabled. Trusted single-tenant hosts only.
QMP_MCP_ALLOW_RAW_ARGS=false
