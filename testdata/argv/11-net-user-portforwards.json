{
  "description": "User-mode networking with two inbound port-forwards built from validated ints; each is pinned to 127.0.0.1 (loopback). The first forward omits proto and defaults to tcp.",
  "spec": {
    "network": {
      "hostForwards": [
        { "hostPort": 8022, "guestPort": 22 },
        { "hostPort": 15353, "guestPort": 53, "proto": "udp" }
      ]
    }
  },
  "options": { "accel": "tcg", "hostfwdPortRange": { "low": 1024, "high": 65535 } },
  "expectedArgv": [
    "-machine", "q35,accel=tcg",
    "-cpu", "max",
    "-smp", "1",
    "-m", "256",
    "-nodefaults",
    "-nographic",
    "-S",
    "-netdev", "user,id=net0,hostfwd=tcp:127.0.0.1:8022-:22,hostfwd=udp:127.0.0.1:15353-:53",
    "-device", "virtio-net-pci,netdev=net0",
    "-qmp", "unix:{{QMP_SOCKET}},server=on,wait=off"
  ]
}
